<div id="requesting-latest-quota-changes">
<section id="section-5.2">
        <h3 id="name-requesting-latest-quota-cha"><a href="#section-5.2">5.2.&nbsp;&nbsp;Requesting Latest Quota Changes</a></h3>
<p id="section-5.2-1">Request fetching the changes for a specific quota:<a href="#section-5.2-1" class="pilcrow">¶</a></p>
<div class="lang-json sourcecode" id="section-5.2-2">
<pre>[[ "Quota/changes", {
  "accountId": "u33084183",
  "sinceState": "78540",
  "maxChanges": 20
}, "0" ],
[ "Quota/get", {
  "accountId": "u33084183",
  "#ids": {
    "resultOf": "0",
    "name": "Quota/changes",
    "path": "/updated"
  },
  "#properties": {
    "resultOf": "0",
    "name": "Quota/changes",
    "path": "/updatedProperties"
  }
}, "1" ]]
</pre><a href="#section-5.2-2" class="pilcrow">¶</a>
</div>
<p id="section-5.2-3">With response:<a href="#section-5.2-3" class="pilcrow">¶</a></p>
<div class="lang-json sourcecode" id="section-5.2-4">
<pre>[[ "Quota/changes", {
  "accountId": "u33084183",
  "oldState": "78540",
  "newState": "78542",
  "hasMoreChanges": false,
  "updatedProperties": ["used"],
  "created": [],
  "updated": ["2a06df0d-9865-4e74-a92f-74dcc814270e"],
  "destroyed": []
}, "0" ],
[ "Quota/get", {
  "accountId": "u33084183",
  "state": "10826",
  "list": [{
    "id": "2a06df0d-9865-4e74-a92f-74dcc814270e",
    "used": 1246
  }],
  "notFound": []
}, "1" ]]
</pre><a href="#section-5.2-4" class="pilcrow">¶</a>
</div>
</section>
</div>

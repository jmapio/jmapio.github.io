<section class='section section--alt section--get-started'>
    <div class='u-wrapper'>
        <span class='section__label'>Get started</span>
        <h2 class='section__h2'>
            Up and running<br>
            in minutes
        </h2>
        <div class='get-started__grid'>
            <div class='get-started__card'>
                <h4>Discover the endpoint</h4>
                <p>
                    Fetch
                    <code class='section__inline-code'>/.well-known/jmap</code>
                    for the session object &mdash; capabilities, accounts, and all API URLs.
                </p>
            </div>
            <div class='get-started__card'>
                <h4>Authenticate</h4>
                <p>
                    Standard OAuth 2.0 or Bearer tokens. No custom auth protocol to implement. Works with what you
                    already have.
                </p>
            </div>
            <div class='get-started__card'>
                <h4>Make your first call</h4>
                <p>
                    POST a
                    <code class='section__inline-code'>methodCalls</code>
                    array. Query, fetch, and send &mdash; in one HTTP request.
                </p>
            </div>
            <div class='get-started__card'>
                <h4>Subscribe to push</h4>
                <p>Open an EventSource connection. Your UI stays current without polling. All mailboxes, instantly.</p>
            </div>
        </div>
    </div>
</section>


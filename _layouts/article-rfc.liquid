---
layout: default
stylesheets:
    - article-rfc
    - toc
scripts:
    - toc
---
{% if page.permalink contains 'draft' %}
    {% assign eyebrow = 'Draft specification' %}
    {% assign eyebrow_icon = 'exclamation-triangle' %}
    {% assign hero_class = 'hero--page hero--eyebrow-warning' %}
{% else %}
    {% assign eyebrow = 'Specification' %}
    {% assign eyebrow_icon = 'check-badge' %}
    {% assign hero_class = 'hero--page' %}
{% endif %}
{%
    include components/hero.liquid
    class=hero_class
    eyebrow=eyebrow
    eyebrow_icon=eyebrow_icon
    title=page.title
    sub=page.description
%}

<section class='section section--document'>
    <div class='u-wrapper u-article-split'>
        <nav class='u-toc-wrapper'>
            {% include {{ page.toc }} %}
        </nav>
        <article class='u-rfc'>{{ content }}</article>
    </div>
</section>

<button
    class='toc-fab'
    id='toc-fab'
    aria-label='Table of contents'
    aria-expanded='false'
    aria-controls='toc-drawer'
    hidden
>
    {% include icons/bars-3.liquid %}
</button>

<div
    class='toc-drawer'
    id='toc-drawer'
    role='dialog'
    aria-label='Table of contents'
    aria-modal='true'
    hidden
>
    <div class='toc-drawer__backdrop' data-toc-close></div>
    <div class='toc-drawer__panel'>
        <div class='toc-drawer__header'>
            <span class='toc-drawer__title'>Contents</span>
            <button class='toc-drawer__close' data-toc-close aria-label='Close'>
                {% include icons/close.liquid %}
            </button>
        </div>
        <nav class='toc-drawer__nav' id='toc-drawer-nav'></nav>
    </div>
</div>

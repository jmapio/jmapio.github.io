{% assign display_font_name = 'Bricolage Grotesque' %}
{% assign body_font_name = 'DM Sans' %}
{% assign display_font_url = '/fonts/Bricolage_Grotesque/BricolageGrotesque-VariableFont_opsz,wdth,wght.woff2'
    | relative_url
%}
{% assign body_font_url = '/fonts/DM_Sans/DMSans-VariableFont_opsz,wght.woff2' | relative_url %}
{% assign body_font_italic_url = '/fonts/DM_Sans/DMSans-Italic-VariableFont_opsz,wght.woff2' | relative_url %}
<link rel='preload' as='font' type='font/woff2' href='{{ display_font_url }}' crossorigin>
<link rel='preload' as='font' type='font/woff2' href='{{ body_font_url }}' crossorigin>
<link rel='preload' as='font' type='font/woff2' href='{{ body_font_italic_url }}' crossorigin>
<style>
    @font-face {
        font-family: '{{ display_font_name }}';
        font-style: normal;
        font-weight: 200 800;
        font-stretch: 100%;
        font-display: swap;
        src: url({{ display_font_url }}) format('woff2');
        unicode-range:
            U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F,
            U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
        font-family: '{{ body_font_name }}';
        font-style: normal;
        font-weight: 100 1000;
        font-stretch: 100%;
        font-display: swap;
        src: url({{ body_font_url }}) format('woff2');
        unicode-range:
            U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F,
            U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
    @font-face {
        font-family: '{{ body_font_name }}';
        font-style: italic;
        font-weight: 100 1000;
        font-stretch: 100%;
        font-display: swap;
        src: url({{ body_font_italic_url }}) format('woff2');
        unicode-range:
            U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F,
            U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }
</style>
